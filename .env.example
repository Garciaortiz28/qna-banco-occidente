# ══════════════════════════════════════════════════════════
# .env — Asistente Virtual Banco de Occidente v3.0
# Copiar como .env y rellenar con valores reales
# ══════════════════════════════════════════════════════════

# ── Google AI (ya tienes estas) ──────────────────────────
GEMINI_API_KEY=AIzaSy_TU_KEY_AQUI
GEMINI_MODEL=gemini-2.5-flash-lite
YOUTUBE_API_KEY=AIzaSy_TU_KEY_AQUI

# ── Chainlit (generar con: python -c "import secrets; print(secrets.token_hex(32))") ─
CHAINLIT_AUTH_SECRET=genera_clave_aleatoria_de_32_chars

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (emails) ──────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=onboarding@resend.dev

# ── LangSmith (trazabilidad) ─────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__XXXXXXXXXXXXXXXXXXXXXXXX
LANGCHAIN_PROJECT=banco_occidente_v3

# ── Twilio (WhatsApp) ────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_VERIFY_TOKEN=bdo_verify_2026

# ── Servidor ─────────────────────────────────────────────
PORT=8000
